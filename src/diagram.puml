@startuml
[*] --> IDLE

state IDLE
IDLE : entry / log("Enter IDLE")
IDLE : exit / log("Exit IDLE")

state DISPATCHING
DISPATCHING : entry / log("Enter DISPATCHING")
DISPATCHING : exit / log("Exit DISPATCHING")

state MONITORING
MONITORING : entry / log("Enter MONITORING")
MONITORING : exit / log("Exit MONITORING")

state REFILLING
REFILLING : entry / log("Enter REFILLING")
REFILLING : exit / log("Exit REFILLING")

state FAULT_HANDLING
FAULT_HANDLING : entry / log("Enter FAULT_HANDLING")
FAULT_HANDLING : exit / log("Exit FAULT_HANDLING")

IDLE --> DISPATCHING : receiveFireEvent()\n(first fire arrives)
DISPATCHING --> MONITORING : requestMission()\n[queues empty and activeMissionCount>0]
DISPATCHING --> DISPATCHING : requestMission()\n[queues not empty]\nor receiveFireEvent()
MONITORING --> DISPATCHING : receiveFireEvent()\n(new fire while drones active)
MONITORING --> IDLE : missionCompleted()\n[last drone, queues empty]
MONITORING --> MONITORING : missionCompleted()\n[still active drones, queues empty]
IDLE --> REFILLING : droneRefilling()
DISPATCHING --> REFILLING : droneRefilling()
MONITORING --> REFILLING : droneRefilling()
REFILLING --> IDLE : droneRefillComplete()\n[last refill, no active missions, queues empty]
REFILLING --> DISPATCHING : droneRefillComplete()\n[last refill, queues not empty]
REFILLING --> MONITORING : droneRefillComplete()\n[last refill, active missions exist, queues empty]
REFILLING --> REFILLING : droneRefillComplete()\n[still refilling drones]

FAULT_HANDLING --> IDLE : fault resolved\n[no queues, no active missions]
FAULT_HANDLING --> DISPATCHING : fault resolved\n[queues not empty]
FAULT_HANDLING --> MONITORING : fault resolved\n[active missions exist]
FAULT_HANDLING --> REFILLING : fault resolved\n[refilling drones exist]
@enduml